{
    "name": "Faceit Extension",
    "description": "FACEIT match room overlay extension",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "faceit_extension.html"
    },

    "content_scripts": [
        {
            "matches": ["https://www.faceit.com/*"],
            "js": ["dist/content.js"]
        
        }
    ],
    "background": {
        "service_worker": "dist/service_worker.js",
        "type": "module"

    }   
}